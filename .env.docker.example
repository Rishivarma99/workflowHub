# Copy to .env.docker and set your backend API base URL (no trailing slash).
#   Copy-Item .env.docker.example .env.docker
#
# The Angular dev server proxies browser calls from /api/* to this target.
#
# --- Local .NET on your machine (default) ---
#   dotnet run --project WorkflowHub.Api   →  http://localhost:5031
#   From inside Docker use host.docker.internal:
API_PROXY_TARGET=http://host.docker.internal:5031
#
# --- Backend running in Docker (workflowHub-backend, port 8080) ---
# API_PROXY_TARGET=http://host.docker.internal:8080
#
# --- Remote dev API (e.g. Render) ---
# API_PROXY_TARGET=https://your-workflowhub-dev-api.onrender.com
